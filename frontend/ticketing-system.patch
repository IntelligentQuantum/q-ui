+const STAFF_FILTERS = ['all', 'open', 'assigned_to_me', 'unassigned', 'escalated', 'urgent', 'closed', 'today', 'week'];
+const USER_FILTERS = ['all', 'open', 'closed'];
+
+export default function TicketsPage()
+{

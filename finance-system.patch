+import { useMemo } from 'react';
+import { useTranslation } from 'react-i18next';
+import { useQuery } from '@tanstack/react-query';
+import {
+    Banknote, CircleCheck, CircleDollarSign, Clock, Gift, Receipt, RotateCcw,

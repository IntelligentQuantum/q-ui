# Ignore editor and IDE settings
.idea/
.vscode/
.cursor/
.claude/
.cache/
.sync*

# Ignore log files
*.log

# Ignore temporary files
tmp/
*.tar.gz

# Ignore build and distribution directories
backup/
bin/
build/
dist/
!internal/web/dist/
internal/web/dist/*
!internal/web/dist/.gitkeep
release/
node_modules/

# Ignore Go vendor directory (created transiently by build.sh for offline Docker builds)
vendor/

# Ignore compiled binaries
main

# Ignore script and executable files
/release.sh
/q-ui
# Legacy pre-rename binary / local dev data folder (x-ui -> q-ui)
/x-ui

# Ignore OS specific files
.DS_Store
Thumbs.db

# Ignore Go build files
*.exe
q-ui.db
q-ui.db-shm
q-ui.db-wal
# Legacy pre-rename SQLite files (x-ui -> q-ui)
x-ui.db
x-ui.db-shm
x-ui.db-wal
system_metrics.gob
*.dump

# Ignore Docker specific files
docker-compose.override.yml

# Ignore .env (Environment Variables) file
.env
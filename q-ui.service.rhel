[Unit]
Description=q-ui Service
After=network.target
Wants=network.target

[Service]
EnvironmentFile=-/etc/sysconfig/q-ui
Environment="XRAY_VMESS_AEAD_FORCED=false"
Type=simple
WorkingDirectory=/usr/local/q-ui/
ExecStart=/usr/local/q-ui/q-ui
ExecReload=kill -USR1 $MAINPID
Restart=on-failure
RestartSec=5s

[Install]
WantedBy=multi-user.target

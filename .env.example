# 3x-ui environment configuration.
# Copy to ".env" and adjust. All variables are optional and fall back to the
# defaults shown here when unset.

# --- General ---
# Enable verbose debug logging and the Gin debug mode.
QUI_DEBUG=true
# Log verbosity when QUI_DEBUG is false: debug | info | notice | warning | error
QUI_LOG_LEVEL=info
# Skip sending the HSTS header even when serving direct HTTPS.
QUI_SKIP_HSTS=false

# --- Paths ---
# Where q-ui.db (SQLite), logs and the xray binary/geo files live.
QUI_DB_FOLDER=q-ui
QUI_LOG_FOLDER=q-ui
QUI_BIN_FOLDER=q-ui

# --- Database ---
# Backend: "sqlite" (default) or "postgres".
# QUI_DB_TYPE=sqlite
# PostgreSQL DSN, required only when QUI_DB_TYPE=postgres. The target database
# must already exist; tables are auto-migrated on start.
# QUI_DB_DSN=postgres://postgres:root@127.0.0.1:5432/xui?sslmode=disable
# Connection pool sizing (defaults: sqlite 8/4, postgres 25/25).
# QUI_DB_MAX_OPEN_CONNS=25
# QUI_DB_MAX_IDLE_CONNS=25

# --- Web ---
# Initial web base path applied on first boot (e.g. "/" or "/mypanel/").
# XUI_INIT_WEB_BASE_PATH=/
# Override the listen port at startup (otherwise uses the stored webPort).
# XUI_PORT=8080
